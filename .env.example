# ═══════════════════════════════════════════════════════════════════════════════
#  Titan API — Environment Variables
#  Copy this file to .env and fill in the values marked REPLACE_*
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secret key ────────────────────────────────────────────────────────────────
# Used to sign JWTs and any HMAC operations. Set once, never rotate in prod
# (rotating it invalidates all active tokens/sessions).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHAR_SECRET

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=titan
DB_PASSWORD=REPLACE_DB_PASSWORD
DB_NAME=titan
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Required — no default allowed.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100

# ── Workers (0 = auto: 2×CPU+1) ───────────────────────────────────────────────
WORKERS_COUNT=0

# ── ARQ (background jobs) ────────────────────────────────────────────────────
ARQ_QUEUE_NAME=titan:queue
ARQ_MAX_JOBS=100
ARQ_JOB_TIMEOUT_SECONDS=300
ARQ_KEEP_RESULT_SECONDS=3600

# ── Credits ───────────────────────────────────────────────────────────────────
FREE_LIFETIME_CREDITS=75
CREDITS_INTERNAL_API_KEY=REPLACE_WITH_STRONG_SERVICE_SECRET
# Set to true to let authenticated users self-add credits via POST /credits/self-topup
ENABLE_CREDIT_SELF_TOPUP=false
CREDIT_SELF_TOPUP_AMOUNT=75

# ── Design / Higgsfield AI ────────────────────────────────────────────────────
DESIGN_UPLOAD_DIR=/tmp/titan/design-inputs
DESIGN_UPLOAD_MAX_MB=15
DESIGN_OUTPUT_DIR=/tmp/titan/design-outputs
HIGGSFIELD_TIMEOUT_MINUTES=20
HIGGSFIELD_BIN=higgsfield
HIGGSFIELD_DESIGN_MODEL=seedream_v4_5
HIGGSFIELD_DESIGN_QUALITY=high
HIGGSFIELD_DESIGN_ASPECT_RATIO=1:1

# ── Migrations ────────────────────────────────────────────────────────────────
# Set to true on first deploy to auto-run alembic upgrade head, then false.
RUN_MIGRATIONS=false

# ── Nginx config (VPS / Docker Compose only — ignored by Coolify) ──────────
# Local / first boot: titan.conf   Production (after make ssl): titan-prod.conf
NGINX_CONF=titan.conf
