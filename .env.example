# ═══════════════════════════════════════════════════════════════════════════════
#  Titan API — Environment Variables
#  Copy this file to .env and fill in the values marked REPLACE_*
# ═══════════════════════════════════════════════════════════════════════════════

# ── Secret key ────────────────────────────────────────────────────────────────
# Used to sign JWTs and any HMAC operations. Set once, never rotate in prod
# (rotating it invalidates all active tokens/sessions).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHAR_SECRET

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=titan
DB_PASSWORD=REPLACE_DB_PASSWORD
DB_NAME=titan
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Required — no default allowed.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_MAX_CONNECTIONS=100

# ── Workers (0 = auto: 2×CPU+1) ───────────────────────────────────────────────
WORKERS_COUNT=0

# ── ARQ (background jobs) ────────────────────────────────────────────────────
ARQ_QUEUE_NAME=titan:queue
ARQ_MAX_JOBS=100
ARQ_JOB_TIMEOUT_SECONDS=300
ARQ_KEEP_RESULT_SECONDS=3600

# ── Credits ───────────────────────────────────────────────────────────────────
FREE_LIFETIME_CREDITS=75
CREDITS_INTERNAL_API_KEY=REPLACE_WITH_STRONG_SERVICE_SECRET
# Set to true to let authenticated users self-add credits via POST /credits/self-topup
ENABLE_CREDIT_SELF_TOPUP=false
CREDIT_SELF_TOPUP_AMOUNT=75

# ── Design Generation Providers ───────────────────────────────────────────────
DESIGN_UPLOAD_DIR=/tmp/titan/design-inputs
# Hard server-side cap for uploaded input image payload size.
DESIGN_UPLOAD_MAX_MB=15
DESIGN_OUTPUT_DIR=/tmp/titan/design-outputs

# Primary provider: fal (default) or higgsfield
DESIGN_GENERATION_PROVIDER=fal

# fal.ai (primary)
# Required when DESIGN_GENERATION_PROVIDER=fal
FAL_KEY=REPLACE_WITH_FAL_API_KEY
FAL_TIMEOUT_MINUTES=20
FAL_DESIGN_MODEL=fal-ai/nano-banana-pro/edit
FAL_DESIGN_ASPECT_RATIO=1:1
FAL_DESIGN_RESOLUTION=1K
FAL_DESIGN_OUTPUT_FORMAT=png

# Higgsfield backend (optional; disabled by default)
ENABLE_HIGGSFIELD_BACKEND=false
HIGGSFIELD_TIMEOUT_MINUTES=20
HIGGSFIELD_BIN=higgsfield
HIGGSFIELD_DESIGN_MODEL=seedream_v4_5
HIGGSFIELD_DESIGN_QUALITY=high
HIGGSFIELD_DESIGN_ASPECT_RATIO=1:1

# ── Cloudflare R2 (S3-compatible object storage) ──────────────────────────────
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET_NAME=titan-inputs
# R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
# R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_KEY
# R2_PUBLIC_URL=https://pub-<hash>.r2.dev
# R2_PRESIGNED_URL_EXPIRY=3600

# ── Migrations ────────────────────────────────────────────────────────────────
# Set to true on first deploy to auto-run alembic upgrade head, then false.
RUN_MIGRATIONS=false

# ── RevenueCat ─────────────────────────────────────────────────────────────────
# RevenueCat API key for server-side API access (not the public SDK key)
REVENUECAT_API_KEY=REPLACE_WITH_REVENUECAT_SERVER_API_KEY
# Webhook secret configured in RevenueCat dashboard → Integrations → Webhooks
REVENUECAT_WEBHOOK_SECRET=REPLACE_WITH_REVENUECAT_WEBHOOK_SECRET
# Store product IDs/SKUs used in App Store Connect / Google Play.
# These must match the product_id sent in RevenueCat webhooks and API responses.
# Do NOT use package labels like "weekly" / "yearly" here.
SUBSCRIPTION_WEEKLY_PRODUCT_ID=REPLACE_WITH_WEEKLY_STORE_SKU
SUBSCRIPTION_YEARLY_PRODUCT_ID=REPLACE_WITH_YEARLY_STORE_SKU
# Credits granted per subscription period
SUBSCRIPTION_WEEKLY_CREDITS=350
SUBSCRIPTION_YEARLY_CREDITS=2000

# ── Nginx config (VPS / Docker Compose only — ignored by Coolify) ──────────
# Local / first boot: titan.conf   Production (after make ssl): titan-prod.conf
NGINX_CONF=titan.conf
