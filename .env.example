# ── Secret key ────────────────────────────────────────────────────────────────
# Used to sign JWTs and any HMAC operations. Set once, never rotate in prod
# (rotating it invalidates all active tokens/sessions).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHAR_SECRET

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=titan
DB_PASSWORD=REPLACE_DB_PASSWORD
DB_NAME=titan
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Required — no default allowed.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_DB=0

# ── Workers (0 = auto: 2×CPU+1) ───────────────────────────────────────────────
WORKERS_COUNT=0

# ── ARQ (background jobs) ────────────────────────────────────────────────────
ARQ_QUEUE_NAME=titan:queue
ARQ_MAX_JOBS=100
ARQ_JOB_TIMEOUT_SECONDS=300
ARQ_KEEP_RESULT_SECONDS=3600

# ── Nginx config ──────────────────────────────────────────────────────────────
# Local: titan.conf   Production (after make ssl): titan-prod.conf
NGINX_CONF=titan.conf

# ── Migrations ────────────────────────────────────────────────────────────────
RUN_MIGRATIONS=false
